DOMAIN=community.example.com
COMMUNITY_NAME="My Community"
COMMUNITY_LOGO_URL=
PRIMARY_COLOR=#3b82f6

ADMIN_NPUB=npub1...
ADMIN_EMAIL=admin@example.com

DATABASE_URL=file:/data/app.db

NEXT_PUBLIC_RELAY_URL=wss://relay.community.example.com
