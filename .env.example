LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

CPDV_API_URL=https://cpdv-bible-production.up.railway.app
CPDV_API_KEY=

SESSION_SECRET=

# Blossom admin dashboard (https://files.{DOMAIN}/admin)
BLOSSOM_ADMIN_USER=admin
BLOSSOM_ADMIN_PASS=
