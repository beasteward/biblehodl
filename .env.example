# Database
DATABASE_URL="file:./dev.db"

# Private Nostr Relay
# Set NEXT_PUBLIC_RELAY_URL to use a private relay instead of public ones
# Leave commented out to use public relays (relay.primal.net, relay.damus.io)
# NEXT_PUBLIC_RELAY_URL="wss://relay.yourdomain.com"

# Relay admin API (for whitelist sync)
# RELAY_ADMIN_URL="http://localhost:3002"
# RELAY_ADMIN_TOKEN="your-secret-token"

# BLOSSOM server
# NEXT_PUBLIC_BLOSSOM_URL="http://localhost:3100"
