{$DOMAIN} {
	reverse_proxy app:3000
}

relay.{$DOMAIN} {
	reverse_proxy relay:8080
}

files.{$DOMAIN} {
	reverse_proxy blossom:3000
}

# LiveKit signaling (WebSocket). Media (RTC) does NOT pass through here — it
# uses the UDP range / TCP 7881 published by the livekit service directly.
livekit.{$DOMAIN} {
	reverse_proxy livekit:7880
}

